{
    "clangd.fallbackFlags": [
        "--cuda-path=/usr/local/cuda",
        "--cuda-gpu-arch=sm_86"
    ],
     "[cuda-cpp]": {
        "editor.tabSize": 4
    },
    "[cpp]": {
        "editor.formatOnSaveMode": "modificationsIfAvailable",
        "editor.formatOnSave": false,
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "editor.tabSize": 4,
    },   
}